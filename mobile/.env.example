# Copy this file to .env.local and fill in values
# Never commit .env.local to git

# Your Cloudflare Worker URL (proxies Gemini API requests)
EXPO_PUBLIC_API_BASE_URL=https://your-worker.your-subdomain.workers.dev

# RevenueCat API Keys (get from https://app.revenuecat.com)
EXPO_PUBLIC_REVENUECAT_IOS_KEY=appl_xxxxxxxxxxxxxxxxxxxxxxxxxxxx
EXPO_PUBLIC_REVENUECAT_ANDROID_KEY=goog_xxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Google AdMob (get from https://admob.google.com)
# Also update app.json with your App IDs
EXPO_PUBLIC_ADMOB_REWARDED_AD_IOS=ca-app-pub-xxxxxxxxxxxxxxxx/xxxxxxxxxx
EXPO_PUBLIC_ADMOB_REWARDED_AD_ANDROID=ca-app-pub-xxxxxxxxxxxxxxxx/xxxxxxxxxx
